# Copy to .env (chmod 600), edit values, source before running the script.
# All values are optional — the script runs without Firebase, just writing a local manifest.

# Where downloaded PDFs land. Nginx must have read access to this path.
KUPPI_PAPERS_ROOT=/var/kuppi/papers

# Where the sync log is written.
KUPPI_PAPERS_LOG=/var/log/kuppi/papers-sync.log

# Firebase Admin (for pushing metadata into Firestore). Reuse the same values
# as the Kuppi web app's .env.local — service account from
# Firebase Console -> Project Settings -> Service accounts.
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
