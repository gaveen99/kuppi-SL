# Firebase Client Configuration
#
# IMPORTANT: NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
# In production, set this to your APP's own domain (e.g. your-domain.com), NOT
# <project>.firebaseapp.com. next.config.js rewrites /__/auth/* and
# /__/firebase/* to the Firebase-hosted handler, so the Firebase JS SDK can
# complete the OAuth flow as a first-party request from your-domain.com.
#
# Why: mobile Safari and mobile Chrome partition third-party storage by
# eTLD+1. When authDomain differs from the app origin, the redirect /
# popup handshake silently fails because the cross-site cookies it relies
# on get dropped. Serving the handler from your-domain.com avoids that entirely
# and works in iOS PWA standalone mode as well.
#
# In local dev (npm run dev), you can either leave AUTH_DOMAIN as
# <project>.firebaseapp.com (popup will work on desktop) or set it to
# localhost — Firebase Console must have the matching authorized domain.
# See docs/auth/google-signin-setup.md for the full setup.
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_app_domain.example
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin (SERVER-ONLY) — used to mint custom tokens for OTP sign-in
# and to manage users. Create a service account in Firebase Console:
#   Project Settings → Service accounts → Generate new private key
# Paste the values from the JSON below. PRIVATE_KEY must include the
# BEGIN/END lines; use \n to represent newlines (quoted).
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# SMTP for sending OTP emails. Gmail example below.
# For Gmail, create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_app_password_here
MAIL_FROM="Kuppi <your_gmail_address@gmail.com>"

# Where messages from the /contact form are delivered.
# Defaults to you@example.com if unset.
CONTACT_INBOX=you@example.com

# Google Sign-In
# 1) Enable Google as a sign-in provider in Firebase Console → Authentication → Sign-in method
# 2) No additional env vars needed — Firebase handles OAuth via the client SDK

# File Upload Configuration
UPLOADS_DIR=./uploads
MAX_FILE_SIZE=10485760

# Google AdSense Configuration
# Get your Publisher ID from https://www.google.com/adsense/
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Ad Unit IDs (create these in your AdSense dashboard)
# Leave as-is or blank to render a visible "Ad Space" placeholder in dev.
# Ads are automatically hidden on /call, /messages, /practice, /exam, /auth.
NEXT_PUBLIC_ADSENSE_HORIZONTAL_SLOT=1234567890
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=1234567891
NEXT_PUBLIC_ADSENSE_INARTICLE_SLOT=1234567892
NEXT_PUBLIC_ADSENSE_INFEED_SLOT=1234567893
NEXT_PUBLIC_ADSENSE_MOBILE_SLOT=1234567894
